{
  "name": "leanprompt",
  "displayName": "LeanPrompt",
  "description": "Write better AI prompts from inside VS Code. Structure your context, trim tokens, copy and paste.",
  "version": "1.0.2",
  "publisher": "stillbuild",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
   "Other"
  ],
  "keywords": [
    "ai",
    "prompt",
    "claude",
    "chatgpt",
    "gemini",
    "tokens",
    "coding"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adi-gyt/leanprompt"
  },
  "activationEvents": [
    "onCommand:leanprompt.open"
  ],
  "contributes": {
    "commands": [
      {
        "command": "leanprompt.open",
        "title": "LeanPrompt: Open",
        "category": "LeanPrompt"
      }
    ],
    "keybindings": [
      {
        "command": "leanprompt.open",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.17.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  }
}
